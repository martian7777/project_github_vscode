{
  "name": "repodeck",
  "displayName": "RepoDeck — GitHub Issues, PRs & Boards",
  "description": "Initialize repos, create and assign issues, and manage GitHub Project boards with a real kanban — without leaving your editor.",
  "version": "0.9.3",
  "publisher": "martian7777",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "github",
    "issues",
    "pull requests",
    "project board",
    "kanban"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/martian7777/repodeck.git"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repodeck",
          "title": "RepoDeck",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "repodeck": [
        {
          "id": "repodeck.issues",
          "name": "Issues"
        },
        {
          "id": "repodeck.pulls",
          "name": "Pull Requests"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "repodeck.issues",
        "contents": "This folder isn't connected to a GitHub repository yet.\n[Initialize Repository](command:repodeck.initRepo)\nAlready have one? Sign in to get started.\n[Sign in to GitHub](command:repodeck.signIn)"
      }
    ],
    "commands": [
      {
        "command": "repodeck.signIn",
        "title": "Sign in to GitHub",
        "category": "RepoDeck"
      },
      {
        "command": "repodeck.signOut",
        "title": "Sign out",
        "category": "RepoDeck"
      },
      {
        "command": "repodeck.initRepo",
        "title": "Initialize Repository",
        "category": "RepoDeck",
        "icon": "$(repo-create)"
      },
      {
        "command": "repodeck.createIssue",
        "title": "Create Issue",
        "category": "RepoDeck",
        "icon": "$(add)"
      },
      {
        "command": "repodeck.openIssue",
        "title": "Open Issue",
        "category": "RepoDeck"
      },
      {
        "command": "repodeck.openIssueOnGitHub",
        "title": "Open Issue on GitHub",
        "category": "RepoDeck",
        "icon": "$(link-external)"
      },
      {
        "command": "repodeck.refreshIssues",
        "title": "Refresh",
        "category": "RepoDeck",
        "icon": "$(refresh)"
      },
      {
        "command": "repodeck.openBoard",
        "title": "Open Project Board",
        "category": "RepoDeck",
        "icon": "$(project)"
      },
      {
        "command": "repodeck.addIssueToBoard",
        "title": "Add Issue to Project Board",
        "category": "RepoDeck"
      },
      {
        "command": "repodeck.createPr",
        "title": "Create Pull Request",
        "category": "RepoDeck",
        "icon": "$(add)"
      },
      {
        "command": "repodeck.refreshPulls",
        "title": "Refresh Pull Requests",
        "category": "RepoDeck",
        "icon": "$(refresh)"
      },
      {
        "command": "repodeck.openPr",
        "title": "Open Pull Request",
        "category": "RepoDeck"
      },
      {
        "command": "repodeck.checkoutPr",
        "title": "Check Out Pull Request",
        "category": "RepoDeck",
        "icon": "$(cloud-download)"
      },
      {
        "command": "repodeck.mergePr",
        "title": "Merge Pull Request",
        "category": "RepoDeck",
        "icon": "$(git-merge)"
      },
      {
        "command": "repodeck.closePr",
        "title": "Close Pull Request",
        "category": "RepoDeck"
      },
      {
        "command": "repodeck.createProject",
        "title": "New Project Board",
        "category": "RepoDeck",
        "icon": "$(add)"
      },
      {
        "command": "repodeck.readyForReview",
        "title": "Mark Ready for Review",
        "category": "RepoDeck"
      },
      {
        "command": "repodeck.startWorkOnIssue",
        "title": "Start Working on Issue",
        "category": "RepoDeck",
        "icon": "$(git-branch)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "repodeck.createIssue",
          "when": "view == repodeck.issues && repodeck:hasRepo",
          "group": "navigation@1"
        },
        {
          "command": "repodeck.openBoard",
          "when": "view == repodeck.issues && repodeck:hasRepo",
          "group": "navigation@2"
        },
        {
          "command": "repodeck.refreshIssues",
          "when": "view == repodeck.issues",
          "group": "navigation@3"
        },
        {
          "command": "repodeck.createPr",
          "when": "view == repodeck.pulls && repodeck:hasRepo",
          "group": "navigation@1"
        },
        {
          "command": "repodeck.refreshPulls",
          "when": "view == repodeck.pulls",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "repodeck.addIssueToBoard",
          "when": "view == repodeck.issues && viewItem == issue",
          "group": "inline@1"
        },
        {
          "command": "repodeck.startWorkOnIssue",
          "when": "view == repodeck.issues && viewItem == issue",
          "group": "inline@2"
        },
        {
          "command": "repodeck.openIssueOnGitHub",
          "when": "view == repodeck.issues && viewItem == issue",
          "group": "inline@3"
        },
        {
          "command": "repodeck.checkoutPr",
          "when": "view == repodeck.pulls && viewItem == pull",
          "group": "inline@1"
        },
        {
          "command": "repodeck.mergePr",
          "when": "view == repodeck.pulls && viewItem == pull",
          "group": "inline@2"
        },
        {
          "command": "repodeck.closePr",
          "when": "view == repodeck.pulls && viewItem == pull",
          "group": "1_modify"
        },
        {
          "command": "repodeck.readyForReview",
          "when": "view == repodeck.pulls && viewItem == pull",
          "group": "1_modify"
        }
      ]
    },
    "configuration": {
      "title": "RepoDeck",
      "properties": {
        "repodeck.remoteName": {
          "type": "string",
          "default": "origin",
          "description": "The git remote RepoDeck reads the GitHub owner/repo from."
        },
        "repodeck.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Node ID of the GitHub Project to open by default for this workspace."
        },
        "repodeck.boardField": {
          "type": "string",
          "default": "",
          "description": "Node ID of the single-select field the board groups by. Empty means the project's first single-select field."
        },
        "repodeck.layout": {
          "type": "string",
          "enum": [
            "table",
            "board",
            "roadmap"
          ],
          "default": "board",
          "description": "Which layout the project panel opens in."
        },
        "repodeck.roadmapStart": {
          "type": "string",
          "default": "",
          "description": "Node ID of the date field the roadmap uses as the start date."
        },
        "repodeck.roadmapTarget": {
          "type": "string",
          "default": "",
          "description": "Node ID of the date field the roadmap uses as the target date."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production && vsce package",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "dependencies": {
    "@octokit/plugin-retry": "^7.2.1",
    "@octokit/plugin-throttling": "^9.6.1",
    "@octokit/rest": "^21.0.2",
    "marked": "^14.1.4",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.0",
    "ovsx": "^0.10.1",
    "typescript": "^5.6.3"
  }
}
